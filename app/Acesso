        </JModal>
      )}

      {modal==='fechamento'&&(
        <JModal title="Fechar Atendimento" onClose={closeModal}>
          <Box cor="green"><strong>{form.client_name}</strong> \u2014 {form.service_name}<br/><span style={{fontSize:11,opacity:.8}}>{form.professional_name} \u00b7 {form.data} \u00e0s {form.horario}</span></Box>
          <Lbl>Valor do servi\u00e7o</Lbl><Inp value={`R$ ${form.valorOriginal||0}`} disabled/>
          <Lbl>Valor cobrado *</Lbl><Inp type="number" value={form.valorCobrado||''} onChange={F('valorCobrado')} placeholder="Valor recebido"/>
          {form.valorCobrado&&Number(form.valorCobrado)<Number(form.valorOriginal)&&<Box cor="amber">\u26a0\ufe0f Desconto de R$ {(Number(form.valorOriginal)-Number(form.valorCobrado)).toFixed(2)}</Box>}
          <Lbl>Pagamento</Lbl>
          <Sel value={form.payment_method||'cash'} onChange={F('payment_method')}>
            <option value="cash">\ud83d\udcb5 Dinheiro</option>
            <option value="pix">\ud83d\udcf1 PIX</option>
            <option value="credit_card">\ud83d\udcb3 Cr\u00e9dito</option>
            <option value="debit_card">\ud83d\udcb3 D\u00e9bito</option>
          </Sel>
          {ferr&&<Box cor="red">{ferr}</Box>}
          <div style={{display:'flex',gap:10,marginTop:20}}>
            <button className="j-btn j-btn-primary" style={{flex:1,justifyContent:'center',background:'linear-gradient(135deg,#2e7d32,#1b5e20)',boxShadow:'0 4px 16px rgba(46,125,50,.3)'}} onClick={confirmarFechamento}>\u2713 Confirmar</button>
            <button className="j-btn j-btn-ghost" onClick={closeModal}>Cancelar</button>
          </div>
        </JModal>
      )}

      {modal==='cliente'&&(
        <JModal title={form.id?'Editar Cliente':'Novo Cliente'} onClose={closeModal}>
          <Lbl>Nome *</Lbl><Inp value={form.full_name} onChange={F('full_name')} placeholder="Nome completo"/>
          <Lbl>Telefone</Lbl><Inp value={form.phone} onChange={F('phone')} placeholder="(11) 99999-0000"/>
          <Lbl>E-mail</Lbl><Inp value={form.email} onChange={F('email')} placeholder="email@email.com"/>
          {ferr&&<Box cor="red">{ferr}</Box>}
          <div style={{display:'flex',gap:10,marginTop:20}}>
            <button className="j-btn j-btn-primary" style={{flex:1,justifyContent:'center'}} onClick={saveCl}>Salvar</button>
            <button className="j-btn j-btn-ghost" onClick={closeModal}>Cancelar</button>
          </div>
        </JModal>
      )}

      {modal==='profissional'&&(
        <JModal title={form.id?'Editar Profissional':'Novo Profissional'} onClose={closeModal}>
          <Lbl>Nome *</Lbl><Inp value={form.full_name} onChange={F('full_name')} placeholder="Nome completo"/>
          <Lbl>Telefone</Lbl><Inp value={form.phone} onChange={F('phone')} placeholder="(11) 99999-0000"/>
          <Lbl>Especialidade</Lbl><Inp value={form.specialty} onChange={F('specialty')} placeholder="Ex: Cabelereira"/>
          <Lbl>Classe *</Lbl>
          <Sel value={form.tipo||''} onChange={F('tipo')}>
            <option value="">Selecionar classe...</option>
            <option value="cabelereiro">\u2702\ufe0f Cabelereiro / Barbeiro</option>
            <option value="manicure">\ud83d\udc85 Manicure / Pedicure / Est\u00e9tica</option>
          </Sel>
          {form.tipo&&<Box cor={form.tipo==='manicure'?'blue':'green'}>{form.tipo==='manicure'?'\ud83d\udc85 Realizar\u00e1 servi\u00e7os de Unhas e Est\u00e9tica':'\u2702\ufe0f Realizar\u00e1 servi\u00e7os de Cabelo e Barba'}</Box>}
          <Lbl>Comiss\u00e3o (%)</Lbl><Inp type="number" value={form.commission_pct} onChange={F('commission_pct')} placeholder="40"/>
          <Lbl>In\u00edcio expediente</Lbl><Sel value={(form.schedule_start||'08:00').slice(0,5)} onChange={F('schedule_start')}>{HORARIOS.map(h=><option key={h}>{h}</option>)}</Sel>
          <Lbl>Fim expediente</Lbl><Sel value={(form.schedule_end||'18:00').slice(0,5)} onChange={F('schedule_end')}>{HORARIOS.map(h=><option key={h}>{h}</option>)}</Sel>
          {!form.id&&<Box cor="green">\ud83d\udd11 Senha padr\u00e3o de acesso: <strong>123456</strong></Box>}
          {ferr&&<Box cor="red">{ferr}</Box>}
          <div style={{display:'flex',gap:10,marginTop:20}}>
            <button className="j-btn j-btn-primary" style={{flex:1,justifyContent:'center'}} onClick={saveProf}>Salvar</button>
            <button className="j-btn j-btn-ghost" onClick={closeModal}>Cancelar</button>
          </div>
        </JModal>
      )}

      {modal==='servico'&&(
        <JModal title={form.id?'Editar Servi\u00e7o':'Novo Servi\u00e7o'} onClose={closeModal}>
          <Lbl>Nome *</Lbl><Inp value={form.name} onChange={F('name')} placeholder="Ex: Corte Feminino"/>
          <Lbl>Categoria</Lbl>
          <Sel value={form.categoria||''} onChange={v=>setForm(f=>({...f,categoria:v,category_id:cats.find(c=>c.name===v)?.id}))}>
            <option value="">Selecionar...</option>
            {cats.map(c=><option key={c.id}>{c.name}</option>)}
          </Sel>
          <Lbl>Classe *</Lbl>
          <Sel value={form.tipo||''} onChange={F('tipo')}>
            <option value="">Selecionar classe...</option>
            <option value="cabelereiro">\u2702\ufe0f Cabelereiro / Barbeiro</option>
            <option value="manicure">\ud83d\udc85 Manicure / Pedicure / Est\u00e9tica</option>
          </Sel>
          {form.tipo&&<Box cor={form.tipo==='manicure'?'blue':'green'}>{form.tipo==='manicure'?'\ud83d\udc85 Apenas Manicure pode realizar este servi\u00e7o':'\u2702\ufe0f Apenas Cabelereiro pode realizar este servi\u00e7o'}</Box>}
          <Lbl>Pre\u00e7o (R$)</Lbl><Inp type="number" value={form.price} onChange={F('price')} placeholder="0"/>
          <Lbl>Dura\u00e7\u00e3o (min)</Lbl><Inp type="number" value={form.duration_min} onChange={F('duration_min')} placeholder="30"/>
          {ferr&&<Box cor="red">{ferr}</Box>}
          <div style={{display:'flex',gap:10,marginTop:20}}>
            <button className="j-btn j-btn-primary" style={{flex:1,justifyContent:'center'}} onClick={saveSrv}>Salvar</button>
            <button className="j-btn j-btn-ghost" onClick={closeModal}>Cancelar</button>
          </div>
        </JModal>
      )}

      {toast&&<div className="j-toast" style={{background:toast.ok?'linear-gradient(135deg,#2e7d32,#1b5e20)':'linear-gradient(135deg,#c62828,#b71c1c)'}}>{toast.msg}</div>}
    </>
  )
}

// \u2500\u2500 PAINEL PROFISSIONAL \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function PainelProfissional({prof, onLogout}) {
  const [tab,    setTab]    = useState('hoje')
  const [loading,setLoading]= useState(false)
  const [toast,  setToast]  = useState(null)
  const [modal,  setModal]  = useState(null)
  const [form,   setForm]   = useState({})
  const [ferr,   setFerr]   = useState('')
  const [ags,    setAgs]    = useState([])
  const [blocks, setBlocks] = useState([])

  function shToast(msg,ok=true){setToast({msg,ok});setTimeout(()=>setToast(null),3000)}
  function F(k){return v=>setForm(f=>({...f,[k]:v}))}
  function closeModal(){setModal(null);setFerr('')}
  function openModal(t,data={}){setForm({...data});setModal(t);setFerr('')}

  const load=useCallback(async()=>{
    setLoading(true)
    const [r1,r2]=await Promise.all([
      supabase.from('salon_bookings').select('*').eq('professional_name',prof.full_name).order('booking_date').order('start_time'),
      supabase.from('salon_blocks').select('*').eq('professional_name',prof.full_name).order('block_date').order('start_time'),
    ])
    setAgs(r1.data||[]); setBlocks(r2.data||[])
    setLoading(false)
  },[prof.full_name])

  useEffect(()=>{ load() },[load])

  const agRows=ags.map(a=>({
    id:a.id, data:isoToDmy(a.booking_date), horario:(a.start_time||'').slice(0,5),
    client_name:a.client_name||'', service_name:a.service_name||'', status:a.status,
    valorOriginal:Number(a.service_price)||Number(a.price_charged)||0,
    valorCobrado:Number(a.price_charged)||0,
    commission_pct:Number(a.commission_pct)||0,
    commission_value:Number(a.commission_value)||0,
    duration_min:Number(a.duration_min)||30,
  }))

  const hoje=hojeStr()
  const agHoje=agRows.filter(a=>a.data===hoje&&a.status!=='cancelled')
  const agProximos=agRows.filter(a=>a.data>hoje&&a.status!=='cancelled'&&a.status!=='completed')
  const agHistorico=agRows.filter(a=>a.status==='completed')
  const mesAtual=new Date().getMonth(),anoAtual=new Date().getFullYear()
  const agMes=agHistorico.filter(a=>{if(!a.data)return false;const[,mm,yyyy]=a.data.split('/');return Number(mm)-1===mesAtual&&Number(yyyy)===anoAtual})
  const fatHoje=agHoje.filter(a=>a.status==='completed').reduce((s,a)=>s+a.valorCobrado,0)
  const comHoje=agHoje.filter(a=>a.status==='completed').reduce((s,a)=>s+a.commission_value,0)
  const fatMes=agMes.reduce((s,a)=>s+a.valorCobrado,0)
  const comMes=agMes.reduce((s,a)=>s+a.commission_value,0)

  async function finalizarAtendimento(){
    if(!form.valorCobrado){setFerr('Informe o valor cobrado');return}
    const valor=Number(form.valorCobrado),pct=prof.commission_pct||0
    const {error}=await supabase.from('salon_bookings').update({
      status:'completed',price_charged:valor,payment_method:form.payment_method||'cash',
      commission_pct:pct,commission_value:Math.round(valor*(pct/100)*100)/100
    }).eq('id',form.id)
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Atendimento finalizado! \u2713'); load()
  }

  async function salvarBloqueio(){
    if(!form.block_date||!form.start_time||!form.end_time){setFerr('Preencha data, in\u00edcio e fim');return}
    if(form.start_time>=form.end_time){setFerr('In\u00edcio deve ser antes do fim');return}
    const payload={professional_name:prof.full_name,block_date:form.block_date,start_time:form.start_time+':00',end_time:form.end_time+':00',reason:form.reason||''}
    const {error}=form.id
      ?await supabase.from('salon_blocks').update(payload).eq('id',form.id)
      :await supabase.from('salon_blocks').insert(payload)
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Bloqueio salvo!'); load()
  }

  const tabs=[{id:'hoje',label:'Hoje',icon:'\ud83d\udcc5'},{id:'proximos',label:'Pr\u00f3ximos',icon:'\ud83d\uddd3'},{id:'rendimentos',label:'Rendimentos',icon:'\u25ce'},{id:'bloqueios',label:'Bloqueios',icon:'\ud83d\udeab'}]

  return(
    <>
      <style>{GLOBAL_STYLES}</style>
      <style>{`
        body { background: ${C.offwhite} !important; }
        .prof-wrap { max-width: 680px; margin: 0 auto; padding: 20px 16px 60px; }
      `}</style>

      <div className="prof-wrap">
        {/* HEADER */}
        <div className="j-card animate-up" style={{marginBottom:16}}>
          <div style={{padding:'18px 20px',display:'flex',alignItems:'center',justifyContent:'space-between',flexWrap:'wrap',gap:10}}>
            <div style={{display:'flex',alignItems:'center',gap:14}}>
              <div style={{width:52,height:52,borderRadius:'50%',background:'linear-gradient(135deg,#f48fb1,#c2185b)',display:'flex',alignItems:'center',justifyContent:'center',fontFamily:'Cormorant Garamond,serif',fontSize:22,fontWeight:700,color:'white',flexShrink:0,boxShadow:'0 4px 16px rgba(194,24,91,.3)'}}>
                {(prof.full_name||'?')[0]}
              </div>
              <div>
                <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:22,fontWeight:600,marginBottom:2}}>Ol\u00e1, {prof.full_name.split(' ')[0]}</div>
                <div style={{display:'flex',alignItems:'center',gap:8,flexWrap:'wrap'}}>
                  <span style={{fontSize:11,color:C.muted}}>{prof.specialty}</span>
                  <Badge tipo={prof.tipo}/>
                  <span style={{fontSize:11,color:C.muted}}>{prof.commission_pct}% comiss\u00e3o</span>
                </div>
              </div>
            </div>
            <div style={{display:'flex',gap:8,alignItems:'center'}}>
              <div style={{padding:'6px 14px',background:C.roseXL,borderRadius:20,fontSize:11,fontWeight:600,color:C.rose,whiteSpace:'nowrap'}}>{new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'short'})}</div>
              <button onClick={onLogout} className="j-btn j-btn-ghost j-btn-sm">Sair</button>
            </div>
          </div>
        </div>

        {/* KPIS */}
        <div className="j-kpis animate-up-1">
          {[
            {l:'Hoje',v:agHoje.length,ic:'\ud83d\udcc5',bg:'linear-gradient(135deg,#fff0f5,#fce4ec)'},
            {l:'Finalizados',v:agHoje.filter(a=>a.status==='completed').length,ic:'\u2705',bg:'linear-gradient(135deg,#f1f8e9,#e8f5e9)'},
            {l:'Fat. Hoje',v:`R$ ${fatHoje}`,ic:'\u25ce',bg:'linear-gradient(135deg,#fffde7,#fff8e1)'},
            {l:'Com. Hoje',v:`R$ ${comHoje.toFixed(2)}`,ic:'\ud83d\udc8e',bg:'linear-gradient(135deg,#f3e5f5,#e8eaf6)'},
          ].map(k=>(
            <div key={k.l} className="j-kpi">
              <div style={{width:34,height:34,borderRadius:10,background:k.bg,display:'flex',alignItems:'center',justifyContent:'center',fontSize:15,marginBottom:8}}>{k.ic}</div>
              <div className="j-kpi-val" style={{fontSize:22}}>{k.v}</div>
              <div className="j-kpi-lbl">{k.l}</div>
            </div>
          ))}
        </div>

        {/* TABS */}
        <div className="j-card animate-up-2">
          <div className="j-tabs">
            {tabs.map(t=><button key={t.id} className={`j-tab${tab===t.id?' active':''}`} onClick={()=>setTab(t.id)}>{t.icon} {t.label}</button>)}
          </div>
          <div style={{padding:16}}>
            {loading&&<div style={{textAlign:'center',padding:32,color:C.muted,fontSize:13}}>Carregando...</div>}
            {!loading&&(<>

              {tab==='hoje'&&(agHoje.length===0
                ? <div style={{textAlign:'center',padding:'28px',color:C.muted,fontSize:13}}>Nenhum agendamento hoje \ud83c\udf38</div>
                : agHoje.map(a=>(
                  <div key={a.id} className={`j-ag-card${a.status==='completed'?' done':''}`}>
                    <div className="j-time-pill" style={{background:a.status==='completed'?C.greenPale:C.roseXL}}>
                      <div style={{fontSize:12,fontWeight:700,color:a.status==='completed'?C.green:C.rose}}>{a.horario}</div>
                      <div style={{fontSize:9,color:C.muted}}>{a.duration_min}m</div>
                    </div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:14,fontWeight:600,marginBottom:2,whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'}}>{a.client_name}</div>
                      <div style={{fontSize:12,color:C.muted}}>{a.service_name}</div>
                      {a.status==='completed'&&<div style={{fontSize:12,fontWeight:600,color:C.green}}>R$ {a.valorCobrado} \u00b7 comiss\u00e3o R$ {a.commission_value.toFixed(2)}</div>}
                    </div>
                    {a.status==='completed'
                      ? <span style={{fontSize:12,fontWeight:700,color:C.green,flexShrink:0}}>\u2713 Finalizado</span>
                      : <button className="j-btn j-btn-green j-btn-sm" onClick={()=>openModal('finalizar',{...a,valorCobrado:a.valorOriginal})}>\u2713 Finalizar</button>
                    }
                  </div>
                ))
              )}

              {tab==='proximos'&&(agProximos.length===0
                ? <div style={{textAlign:'center',padding:'28px',color:C.muted,fontSize:13}}>Nenhum pr\u00f3ximo agendamento \ud83d\udcc5</div>
                : agProximos.map(a=>(
                  <div key={a.id} className="j-ag-card">
                    <div className="j-time-pill" style={{background:C.roseXL,minWidth:56}}>
                      <div style={{fontSize:10,fontWeight:600,color:C.rose}}>{a.data.slice(0,5)}</div>
                      <div style={{fontSize:12,fontWeight:700,color:C.rose}}>{a.horario}</div>
                    </div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:14,fontWeight:600,marginBottom:2,whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'}}>{a.client_name}</div>
                      <div style={{fontSize:12,color:C.muted}}>{a.service_name}</div>
                    </div>
                    <span className="j-badge" style={{background:'#fff8e1',color:'#f57c00',flexShrink:0}}>Agendado</span>
                  </div>
                ))
              )}

              {tab==='rendimentos'&&(<>
                <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12,marginBottom:16}}>
                  {[{l:'Fat. M\u00eas',v:`R$ ${fatMes.toFixed(2)}`},{l:'Com. M\u00eas',v:`R$ ${comMes.toFixed(2)}`}].map(k=>(
                    <div key={k.l} style={{background:'linear-gradient(135deg,#fff0f5,#fce4ec)',borderRadius:16,padding:'18px 16px',border:`1px solid ${C.border}`}}>
                      <div style={{fontSize:9,fontWeight:700,letterSpacing:3,textTransform:'uppercase',color:'rgba(194,24,91,.6)',marginBottom:8}}>{k.l}</div>
                      <div style={{fontFamily:'Cormorant Garamond,serif',fontSize:26,fontWeight:700,color:C.rose}}>{k.v}</div>
                    </div>
                  ))}
                </div>
                <div style={{background:'linear-gradient(135deg,#f3e5f5,#ede7f6)',borderRadius:14,padding:'14px 16px',marginBottom:16,display:'flex',alignItems:'center',gap:14}}>
                  <div style={{width:48,height:48,borderRadius:'50%',background:'linear-gradient(135deg,#c2185b,#880e4f)',display:'flex',alignItems:'center',justifyContent:'center',fontFamily:'Cormorant Garamond,serif',fontSize:18,fontWeight:700,color:'white',flexShrink:0}}>{prof.commission_pct}%</div>
                  <div>
                    <div style={{fontSize:13,fontWeight:600,marginBottom:3}}>Comiss\u00e3o atual: {prof.commission_pct}%</div>
                    <div style={{fontSize:11,color:C.muted,lineHeight:1.5}}>Cada atendimento tem a comiss\u00e3o fixada no fechamento \u2014 n\u00e3o muda se o % for alterado depois.</div>
                  </div>
                </div>
                <div style={{fontSize:9,fontWeight:700,letterSpacing:3,textTransform:'uppercase',color:C.muted,marginBottom:12}}>Servi\u00e7os do m\u00eas</div>
                {agMes.length===0
                  ? <div style={{textAlign:'center',padding:20,color:C.muted,fontSize:13}}>Nenhum servi\u00e7o finalizado este m\u00eas</div>
                  : agMes.map(a=>(
                    <div key={a.id} style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'12px 0',borderBottom:`1px solid ${C.border}`}}>
                      <div><div style={{fontSize:13,fontWeight:600}}>{a.service_name}</div><div style={{fontSize:11,color:C.muted}}>{a.client_name} \u00b7 {a.data} \u00b7 {a.commission_pct}%</div></div>
                      <div style={{textAlign:'right'}}><div style={{fontSize:12,color:C.muted}}>R$ {a.valorCobrado}</div><div style={{fontSize:14,fontWeight:700,color:C.rose}}>+R$ {a.commission_value.toFixed(2)}</div></div>
                    </div>
                  ))
                }
              </>)}

              {tab==='bloqueios'&&(<>
                <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14,gap:8,flexWrap:'wrap'}}>
                  <div style={{fontSize:13,color:C.muted}}>Bloqueie per\u00edodos de indisponibilidade</div>
                  <button className="j-btn j-btn-primary j-btn-sm" onClick={()=>openModal('bloqueio',{block_date:'',start_time:'',end_time:'',reason:''})}>+ Novo Bloqueio</button>
                </div>
                {blocks.length===0
                  ? <div style={{textAlign:'center',padding:28,color:C.muted,fontSize:13}}>Nenhum bloqueio cadastrado \ud83d\uddd3</div>
                  : blocks.map(b=>(
                    <div key={b.id} style={{display:'flex',alignItems:'center',gap:12,padding:'13px',borderRadius:14,border:'1px solid #e0e0e0',marginBottom:10,background:'#f9f9f9'}}>
                      <div style={{width:48,height:48,borderRadius:12,background:'#f0f0f0',display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',flexShrink:0}}>
                        <div style={{fontSize:10,fontWeight:600,color:'#666'}}>{isoToDmy(b.block_date).slice(0,5)}</div>
                        <div style={{fontSize:10,color:'#888'}}>{(b.start_time||'').slice(0,5)}</div>
                      </div>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontSize:13,fontWeight:600}}>{(b.start_time||'').slice(0,5)} \u2013 {(b.end_time||'').slice(0,5)}</div>
                        <div style={{fontSize:11,color:C.muted}}>{isoToDmy(b.block_date)} \u00b7 {b.reason||'Sem motivo informado'}</div>
                      </div>
                      <div style={{display:'flex',gap:6,flexShrink:0}}>
                        <button className="j-btn j-btn-ghost j-btn-sm" onClick={()=>openModal('bloqueio',{...b,start_time:(b.start_time||'').slice(0,5),end_time:(b.end_time||'').slice(0,5)})}>\u270f\ufe0f</button>
                        <button className="j-btn j-btn-danger j-btn-sm" onClick={()=>{if(window.confirm('Remover?'))supabase.from('salon_blocks').delete().eq('id',b.id).then(()=>{shToast('Removido!');load()})}}>\ud83d\uddd1</button>
                      </div>
                    </div>
                  ))
                }
              </>)}

            </>)}
          </div>
        </div>
      </div>

      {modal==='finalizar'&&(
        <JModal title="Finalizar Atendimento" onClose={closeModal}>
