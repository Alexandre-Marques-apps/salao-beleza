          <div style={{width:32,height:32,borderRadius:'50%',background:'linear-gradient(135deg,#f48fb1,#c2185b)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:13,fontWeight:700,color:'white',flexShrink:0}}>A</div>
          <div><div style={{fontSize:13,fontWeight:600,color:'white'}}>Alexandre</div><div style={{fontSize:9,letterSpacing:2,color:'rgba(255,255,255,.4)',textTransform:'uppercase'}}>Administrador</div></div>
        </div>
      </aside>

