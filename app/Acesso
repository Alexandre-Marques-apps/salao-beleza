// \u2500\u2500 PAINEL ADMIN \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function PainelAdmin({onLogout}) {
  const [tab,    setTab]    = useState('dashboard')
  const [sbOpen, setSbOpen] = useState(false)
  const [agData, setAgData] = useState(hojeStr())
  const [busca,  setBusca]  = useState('')
  const [toast,  setToast]  = useState(null)
  const [modal,  setModal]  = useState(null)
  const [form,   setForm]   = useState({})
  const [ferr,   setFerr]   = useState('')
  const [loading,setLoading]= useState(false)
  const [ags,    setAgs]    = useState([])
  const [cls,    setCls]    = useState([])
  const [profs,  setProfs]  = useState([])
  const [srvs,   setSrvs]   = useState([])
  const [cats,   setCats]   = useState([])

  function shToast(msg,ok=true){setToast({msg,ok});setTimeout(()=>setToast(null),3000)}
  function F(k){return v=>setForm(f=>({...f,[k]:v}))}
  function closeModal(){setModal(null);setFerr('')}
  function openModal(t,data={}){setForm({...data});setModal(t);setFerr('')}

  const load = useCallback(async()=>{
    setLoading(true)
    const [r1,r2,r3,r4,r5]=await Promise.all([
      supabase.from('salon_bookings').select('*').order('booking_date').order('start_time'),
      supabase.from('salon_clients').select('*').order('full_name'),
      supabase.from('salon_professionals').select('*').eq('active',true).order('full_name'),
      supabase.from('services').select('*, service_categories(name)').eq('active',true).order('name'),
      supabase.from('service_categories').select('*').order('name'),
    ])
    setAgs(r1.data||[]); setCls(r2.data||[]); setProfs(r3.data||[])
    setSrvs(r4.data||[]); setCats(r5.data||[])
    setLoading(false)
  },[])

  useEffect(()=>{ load() },[load])

  // COMPATIBILIDADE \u2014 sem fallback enganoso
  function srvsCompativeis(nomeProf){
    const p=profs.find(x=>x.full_name===nomeProf)
    if(!p||!p.tipo) return []
    return srvs.filter(s=>s.tipo===p.tipo)
  }

  // HOR\u00c1RIOS \u2014 respeita dura\u00e7\u00e3o do servi\u00e7o
  function horariosLivres(nomeProf,data){
    if(!nomeProf||!data) return HORARIOS
    const p=profs.find(x=>x.full_name===nomeProf)
    if(!p) return []
    const hi=(p.schedule_start||'08:00').slice(0,5)
    const hf=(p.schedule_end||'18:00').slice(0,5)
    const ocupados=agRows
      .filter(a=>a.professional_name===nomeProf&&a.data===data&&a.status!=='cancelled'&&a.id!==form.id)
      .map(a=>{
        const durBanco=Number(a.duration_min)||0
        const srv=srvs.find(s=>s.name===a.service_name)
        const dur=durBanco||Number(srv?.duration_min)||30
        return {ini:toMin(a.horario),fim:toMin(a.horario)+dur}
      })
    const srvAtual=srvs.find(s=>s.name===form.service_name)
    const durAtual=Number(srvAtual?.duration_min)||30
    return HORARIOS.filter(h=>{
      if(h<hi||h>hf) return false
      if(!isFuturo(data,h)) return false
      const ini=toMin(h),fim=ini+durAtual
      if(ocupados.some(iv=>ini<iv.fim&&fim>iv.ini)) return false
      if(fim>toMin(hf)+1) return false
      return true
    })
  }

  // SAVE AGENDAMENTO
  async function saveAg(){
    setFerr('')
    if(!form.client_name||!form.service_name||!form.professional_name||!form.data||!form.start_time){
      setFerr('Preencha todos os campos'); return
    }
    const prof=profs.find(p=>p.full_name===form.professional_name)
    const srv=srvs.find(s=>s.name===form.service_name)
    if(!prof?.tipo){ setFerr('Profissional sem classe definida. Edite o cadastro.'); return }
    if(!srv?.tipo){ setFerr('Servi\u00e7o sem classe definida. Edite o cadastro.'); return }
    if(prof.tipo!==srv.tipo){
      setFerr(`\u274c ${prof.full_name} \u00e9 ${prof.tipo==='manicure'?'Manicure':'Cabelereiro'} \u2014 n\u00e3o pode realizar "${srv.name}" (${srv.tipo==='manicure'?'Manicure':'Cabelereiro'})`); return
    }
    const payload={
      client_name:form.client_name, service_name:form.service_name,
      professional_name:form.professional_name,
      booking_date:dmyToISO(form.data),
      start_time:form.start_time.length===5?form.start_time+':00':form.start_time,
      status:'scheduled', price_charged:srv?.price||0, service_price:srv?.price||0,
      duration_min:srv?.duration_min||30,
    }
    const {error}=form.id
      ?await supabase.from('salon_bookings').update(payload).eq('id',form.id)
      :await supabase.from('salon_bookings').insert(payload)
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Agendamento salvo!'); load()
  }

  async function delAg(id){
    const ag=agRows.find(a=>a.id===id)
    if(ag?.status==='completed'){shToast('Atendimentos finalizados n\u00e3o podem ser exclu\u00eddos.',false);return}
    if(!window.confirm('Excluir este agendamento?'))return
    await supabase.from('salon_bookings').delete().eq('id',id)
    shToast('Removido!'); load()
  }

  async function confirmarFechamento(){
    if(!form.valorCobrado){setFerr('Informe o valor cobrado');return}
    const prof=profs.find(p=>p.full_name===form.professional_name)
    const pct=prof?.commission_pct||0
    const valor=Number(form.valorCobrado)
    const {error}=await supabase.from('salon_bookings').update({
      status:'completed',price_charged:valor,payment_method:form.payment_method||'cash',
      commission_pct:pct,commission_value:Math.round(valor*(pct/100)*100)/100
    }).eq('id',form.id)
    if(error){setFerr('Erro: '+error.message);return}
    const cliente=cls.find(c=>c.full_name===form.client_name)
    if(cliente) await supabase.from('salon_clients').update({
      visits:(cliente.visits||0)+1,
      total_spent:(Number(cliente.total_spent)||0)+valor,
      last_visit:dmyToISO(form.data)
    }).eq('id',cliente.id)
    closeModal(); shToast('Atendimento finalizado! \u2713'); load()
  }

  async function saveCl(){
    if(!form.full_name){setFerr('Informe o nome');return}
    const payload={full_name:form.full_name.trim(),phone:form.phone||'',email:form.email||''}
    const {error}=form.id
      ?await supabase.from('salon_clients').update(payload).eq('id',form.id)
      :await supabase.from('salon_clients').insert(payload)
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Cliente salvo!'); load()
  }

  async function saveProf(){
    if(!form.full_name){setFerr('Informe o nome');return}
    if(!form.tipo){setFerr('Selecione a classe do profissional');return}
    const payload={
      full_name:form.full_name.trim(), phone:form.phone||'',
      specialty:form.specialty||'', tipo:form.tipo,
      commission_pct:Number(form.commission_pct)||40,
      schedule_start:form.schedule_start||'08:00',
      schedule_end:form.schedule_end||'18:00',
      active:true, senha:form.senha||'123456'
    }
    const {error}=form.id
      ?await supabase.from('salon_professionals').update(payload).eq('id',form.id)
      :await supabase.from('salon_professionals').insert(payload)
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Profissional salvo!'); load()
  }

  async function saveSrv(){
    if(!form.name){setFerr('Informe o nome');return}
    if(!form.tipo){setFerr('Selecione a classe do servi\u00e7o');return}
    const cat=cats.find(c=>c.name===form.categoria)
    const {error}=form.id
      ?await supabase.from('services').update({name:form.name.trim(),price:Number(form.price)||0,duration_min:Number(form.duration_min)||30,category_id:cat?.id||null,tipo:form.tipo,active:true}).eq('id',form.id)
      :await supabase.from('services').insert({name:form.name.trim(),price:Number(form.price)||0,duration_min:Number(form.duration_min)||30,category_id:cat?.id||null,tipo:form.tipo,active:true})
    if(error){setFerr('Erro: '+error.message);return}
    closeModal(); shToast('Servi\u00e7o salvo!'); load()
  }

  // COMPUTED
  const agRows=ags.map(a=>({
    id:a.id, data:isoToDmy(a.booking_date), horario:(a.start_time||'').slice(0,5),
    client_name:a.client_name||'', service_name:a.service_name||'',
    professional_name:a.professional_name||'', status:a.status,
    valorOriginal:Number(a.service_price)||Number(a.price_charged)||0,
    valorCobrado:Number(a.price_charged)||0,
    duration_min:Number(a.duration_min)||30,
    commission_pct:Number(a.commission_pct)||0,
    commission_value:Number(a.commission_value)||0,
  }))

  const hoje=hojeStr()
  const agHoje=agRows.filter(a=>a.data===hoje&&a.status!=='cancelled')
  const agendaDia=agRows.filter(a=>a.data===agData&&a.status!=='cancelled')
  const fatHoje=agRows.filter(a=>a.data===hoje&&a.status==='completed').reduce((s,a)=>s+a.valorCobrado,0)
  const fatMes=agRows.filter(a=>a.status==='completed').reduce((s,a)=>s+a.valorCobrado,0)

  // GRADE: c\u00e9lula ocupada \u2014 verifica span de dura\u00e7\u00e3o
  function getCel(h,nomP){
    return agendaDia.find(a=>{
      if(a.professional_name!==nomP) return false
      const inicio=toMin(a.horario)
      const fim=inicio+(a.duration_min||30)
      return toMin(h)>=inicio && toMin(h)<fim
    })
  }
  function isStart(h,nomP){
    return agendaDia.some(a=>a.professional_name===nomP&&a.horario===h)
  }

  const clsFilt=cls.filter(c=>(c.full_name||'').toLowerCase().includes(busca.toLowerCase())||(c.phone||'').includes(busca))

  const menus=[
    {id:'dashboard',icon:'\u2b21',label:'Dashboard'},
    {id:'agenda',icon:'\u25f7',label:'Agenda'},
    {id:'clientes',icon:'\u25c9',label:'Clientes'},
    {id:'profissionais',icon:'\u2726',label:'Profissionais'},
    {id:'servicos',icon:'\u25c8',label:'Servi\u00e7os'},
    {id:'financeiro',icon:'\u25ce',label:'Financeiro'},
    {id:'configuracoes',icon:'\u2299',label:'Config.'},
  ]

  return (
    <>
      <style>{GLOBAL_STYLES}</style>
      <style>{`
        .j-sidebar-logo { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:700; color:white; letter-spacing:3px; }
        .j-sidebar-sub { font-size:8px; letter-spacing:4px; text-transform:uppercase; color:rgba(255,255,255,.35); margin-top:2px; }
        .j-nav-item {
          display:flex; align-items:center; gap:12px; padding:13px 20px;
          cursor:pointer; color:rgba(255,255,255,.55); font-size:13px; font-weight:500;
          border-left:2px solid transparent; transition:all .2s;
        }
        .j-nav-item:hover { color:rgba(255,255,255,.85); background:rgba(255,255,255,.05); }
        .j-nav-item.active { color:white; border-left-color:#f48fb1; background:rgba(255,255,255,.08); }
        .j-nav-icon { font-size:15px; width:20px; text-align:center; flex-shrink:0; opacity:.8; }
        .j-topbar-title { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:600; color:${C.ink}; }
        .j-menu-btn {
          width:40px;height:40px;border-radius:12px;border:1px solid ${C.border};
          background:${C.white};cursor:pointer;display:flex;align-items:center;
          justify-content:center;font-size:18px;color:${C.rose};
          transition:background .2s;
        }
        .j-menu-btn:hover { background:${C.roseXL}; }
      `}</style>

      <div className={`j-overlay${sbOpen?' open':''}`} onClick={()=>setSbOpen(false)}/>

      {/* SIDEBAR */}
      <aside className={`j-sidebar${sbOpen?' open':''}`}>
        <div style={{padding:'24px 20px 18px',borderBottom:'1px solid rgba(255,255,255,.08)'}}>
          <div style={{display:'flex',alignItems:'center',gap:12}}>
            <div style={{width:36,height:36,borderRadius:'50%',background:'linear-gradient(135deg,#d81b60,#880e4f)',display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}}>
              <span style={{fontFamily:'Cormorant Garamond,serif',fontSize:16,fontWeight:700,color:'white'}}>J</span>
            </div>
            <div>
              <div className="j-sidebar-logo">Joudat</div>
              <div className="j-sidebar-sub">Admin Panel</div>
            </div>
            <button onClick={()=>setSbOpen(false)} style={{marginLeft:'auto',background:'rgba(255,255,255,.1)',border:'none',borderRadius:8,width:28,height:28,cursor:'pointer',color:'rgba(255,255,255,.6)',fontSize:16,display:'flex',alignItems:'center',justifyContent:'center'}}>\u00d7</button>
          </div>
        </div>
        <nav style={{flex:1,padding:'12px 0',overflowY:'auto'}}>
          {menus.map(m=>(
            <div key={m.id} className={`j-nav-item${tab===m.id?' active':''}`} onClick={()=>{setTab(m.id);setBusca('');setSbOpen(false)}}>
              <span className="j-nav-icon">{m.icon}</span>
              <span>{m.label}</span>
