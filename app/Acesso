              {new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'short'})}
            </div>
            <button onClick={()=>load()} className="j-btn j-btn-ghost j-btn-sm" title="Atualizar">\u21bb</button>
