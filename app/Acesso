function JModal({title, onClose, children}) {
  return (
    <div className="j-modal-overlay" onClick={e=>e.target===e.currentTarget&&onClose()}>
      <div className="j-modal">
        <div className="j-modal-hd">
          <div className="j-modal-title">{title}</div>
          <button className="j-modal-close" onClick={onClose}>\u00d7</button>
        </div>
        <div className="j-modal-body">{children}</div>
      </div>
    </div>
  )
}

function Lbl({children}){return <label className="j-label">{children}</label>}
function Inp({value,onChange,type='text',placeholder,disabled}){
  return <input type={type} value={value??''} onChange={e=>onChange&&onChange(e.target.value)}
    placeholder={placeholder} disabled={disabled} className="j-input"
    style={disabled?{cursor:'not-allowed'}:{}}/>
}
function Sel({value,onChange,children}){
  return <select value={value??''} onChange={e=>onChange&&onChange(e.target.value)} className="j-select">{children}</select>
}
function Box({cor,children}){
  const map={rose:'j-box-rose',red:'j-box-red',green:'j-box-green',amber:'j-box-amber',blue:'j-box-blue'}
  return <div className={`j-box ${map[cor]||'j-box-rose'}`}>{children}</div>
}
function Badge({tipo}){
  return tipo==='manicure'
    ? <span className="j-badge j-badge-nail">\ud83d\udc85 Manicure</span>
    : <span className="j-badge j-badge-hair">\u2702\ufe0f Cabelereiro</span>
}

// \u2500\u2500 LOGIN \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function LoginScreen({onLoginAdmin, onLoginProf}) {
  const [usuario,  setUsuario]  = useState('')
  const [senha,    setSenha]    = useState('')
  const [erro,     setErro]     = useState('')
  const [loading,  setLoading]  = useState(false)
  const [profs,    setProfs]    = useState([])

  useEffect(()=>{
    supabase.from('salon_professionals').select('id,full_name,specialty,tipo').eq('active',true).order('full_name')
      .then(({data})=>{ if(data) setProfs(data) })
  },[])

  async function handleLogin() {
    if(!usuario.trim()){ setErro('Informe seu nome ou usu\u00e1rio'); return }
    if(!senha){ setErro('Informe sua senha'); return }
    setLoading(true); setErro('')

    // Admin
    if(usuario.trim()===ADMIN_USER && senha===ADMIN_PASS){
      setLoading(false); onLoginAdmin(); return
    }

    // Profissional
    const {data,error}=await supabase.from('salon_professionals')
      .select('*').ilike('full_name',usuario.trim()).eq('active',true).single()
    setLoading(false)
    if(error||!data){ setErro('Usu\u00e1rio n\u00e3o encontrado'); return }
    if(senha!==(data.senha||'123456')){ setErro('Senha incorreta'); return }
    onLoginProf(data)
  }

  return (
    <>
      <style>{GLOBAL_STYLES}</style>
      <style>{`
        body { background: linear-gradient(135deg, #1a0a14 0%, #2d1020 50%, #1a0a14 100%) !important; }
